{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
	
	"properties": {
		
		"csv": {
			"type": "string",
			"format": "file-path",
			"exists": true,
			"pattern": "^\\S+\\.(csv)$",
			"description": "Path to a CSV file containing the readsets."
		},
		
		"reads": {
			"title": "Reads definition",
			"type": "object",
			"properties": {
				"long": {
					"type": "string",
					"format": "file-path-pattern",
					"exists": true,
					"pattern": "^\\S+\\.(bam|fastq\\.gz|fq\\.gz)$",
					"description": "Path to BAM or FASTQ.GZ files containing ONT reads"
				},
				"short": {
					"type": "string",
					"format": "file-path-pattern",
					"exists": true,
					"pattern": "^\\S+\\.(fastq\\.gz|fq\\.gz)$",
					"description": "Path to FASTQ.GZ files containing short reads. Pairend-end files are reconized when ending with regex pattern '_(R?[12])(_[0-9][0-9][0-9])?.(fq|fastq).gz$'"
				}
			}
		},
		
		"verbose": {
			"type": "boolean",
			"default": false,
			"description": "If on, the pipeline will produce extended outputs for debugging purpose"
		},
		
		"assemblies": {
			"title": "Assemblies definition",
			"type": "object",
			"properties": {
				"fasta": {
					"type": "string",
					"format": "file-path-pattern",
					"exists": true,
					"pattern": "^\\S+\\.(fasta|fa|fna)$",
					"description": "Path to FASTA file containing assembly contigs"
				}
			}
		},
		
		"reads_filter": {
			"title": "Parameters for tool reads_filter",
			"type": "object",
			"properties": {
				"skip": {
					"type": "boolean",
					"description": "Should read filtering be skipped to work with given reads",
					"default": false
				},
		    "long_limit": {
		      "type": "integer",
		      "description": "Limit the number input reads to this maximum total length (in bp), -1 to skip",
		      "default": 1000000000
		    },
		    "short_limit": {
		      "type": "integer",
		      "description": "Limit the number input reads to this maximum total length (in bp), -1 to skip",
		      "default": 1000000000
		    },
		    "chopper_args": {
		      "type": "string",
		      "description": "Parameters to be used for chooper",
		      "default": "--quality 15 --minlength 200"
		    }
			}
		},

		"reads_qc": {
			"title": "Parameters for tool reads_qc",
			"type": "object",
			"properties": {
				"skip": {
					"type": "boolean",
					"description": "Should read qc be skipped",
					"default": false
				}
			}
		},

		"assemblies_qc": {
			"title": "Parameters for tool assemblies_qc",
			"type": "object",
			"properties": {
					"checkm2": {
					  "type": "object",
						"properties": {
							"skip": {
							  "type": "boolean",
							  "default": false
							},
							"args": {
							  "type": "string",
							  "default": ""
							},
							"db": {
							  "type": "string",
								"format": "directory-path",
								"exists": true
							}
						}
					}
			}
		},		
		
		
		
		"amr": {
			"title": "Parameters for tool amr annotation",
			"type": "object",
			"properties": {
					"orgfinder": {
					  "type": "object",
						"properties": {
							"skip": {
							  "type": "boolean",
							  "default": false
							},
							"args": {
							  "type": "string",
							  "default": ""
							},
							"db": {
							  "type": "string",
								"format": "directory-path",
								"exists": true
							}
						}
					},
					"speciator": {
					  "type": "object",
						"properties": {
							"skip": {
							  "type": "boolean",
							  "default": true
							},
							"args": {
							  "type": "string",
							  "default": ""
							}
						}
					},
					"amrfinderplus": {
					  "type": "object",
						"properties": {
							"skip": {
							  "type": "boolean",
							  "default": false
							},
							"args": {
							  "type": "string",
							  "default": ""
							}
						}
					},
					"mobtyper": {
					  "type": "object",
						"properties": {
							"skip": {
							  "type": "boolean",
							  "default": false
							},
							"args": {
							  "type": "string",
							  "default": ""
							}
						}
					},
					"plasmidfinder": {
					  "type": "object",
						"properties": {
							"skip": {
							  "type": "boolean",
							  "default": false
							},
							"skip_shortread": {
							  "type": "boolean",
							  "default": false
							},
							"skip_longread": {
							  "type": "boolean",
							  "default": false
							},
							"args": {
							  "type": "string",
							  "default": ""
							}
						}
					},
					"resfinder": {
					  "type": "object",
						"properties": {
							"skip": {
							  "type": "boolean",
							  "default": false
							},
							"skip_shortread": {
							  "type": "boolean",
							  "default": false
							},
							"skip_longread": {
							  "type": "boolean",
							  "default": false
							},
							"args": {
							  "type": "string",
							  "default": ""
							}
						}
					},
					"cgemlst": {
					  "type": "object",
						"properties": {
							"skip": {
							  "type": "boolean",
							  "default": false
							},
							"args": {
							  "type": "string",
							  "default": ""
							}
						}
					},
					"MLST": {
					  "type": "object",
						"properties": {
							"skip": {
							  "type": "boolean",
							  "default": false
							},
							"args": {
							  "type": "string",
							  "default": ""
							}
						}
					},
					"prokka": {
					  "type": "object",
						"properties": {
							"skip": {
							  "type": "boolean",
							  "default": true
							},
							"args": {
							  "type": "string",
							  "default": "--kingdom Bacteria"
							}
						}
					}
			}
		},
				
		"assembler": {
			"title": "Assembler definition",
			"type": "object",
			"properties": {
		    "name": {
		      "type": "string",
		      "default": "long_flye_medaka",
		      "enum": [
		      	"long_flye",
		        "long_flye_medaka",
		        "long_hybracter",
		        "long_unicycler",
		        "short_spades",
		        "short_unicycler",
		        "hybrid_unicycler",
		        "hybrid_hybracter",
		        "hybrid_flye_medaka_pilon"
		      ]
		    },
				"args": {
					"type": "object",
					"description": "Argument to pass to the assembler",
					"properties": {
						"flye": {
							"type": "string"
						},
						"medaka": {
							"type": "string",
							"default": "--bacteria"
						},
						"spades": {
							"type": "string"
						},
						"unicycler": {
							"type": "string"
						},
						"hybracter": {
							"type": "string"
						}
					}
				}
			}
		}


		
	}
}