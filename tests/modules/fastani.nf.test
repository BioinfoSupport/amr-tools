nextflow_process {

    name "Test Process FASTANI"
    script "modules/fastani/main.nf"
    process "FASTANI"
    
    test("Should run without failures") {

        when {
            params {
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = tuple([:],file("${projectDir}/tests/data/*.fasta"),file("${projectDir}/tests/data/*.fasta"))
                """
            }
        }

        then {
            assert process.success
            assert process.out[0].size() == 1
        }

    }

}
